      {
        "name": "_Measures",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "HiddenMeasures",
            "dataType": "int64",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "sourceColumn": "[SampleColumn]"
          },
          {
            "type": "calculated",
            "name": "VisibleMeasures",
            "dataType": "int64",
            "isDataTypeInferred": true
          }
        ],
        "partitions": [
          {
            "name": "CalculatedTable 1",
            "source": {
              "type": "calculated",
              "expression": "ROW(\"SampleColumn\", BLANK())"
            }
          }
        ],
        "measures": [
          {
            "name": "_LastDataDateKey",
            "expression": " MAXX(ALL(Fact_CustomerSnapshot), Fact_CustomerSnapshot[DateKey])",
            "isHidden": true
          },
          {
            "name": "_LastDataMonth",
            "expression": [
              " ",
              "VAR MaxKey = [_LastDataDateKey]",
              "RETURN ",
              "CALCULATE( ",
              "    MAX(Dim_Date[Year Month]), ",
              "    Dim_Date[DateKey] = MaxKey ",
              ")"
            ],
            "isHidden": true
          },
          {
            "name": "_PrevDataDateKey",
            "expression": [
              " ",
              "VAR MaxKey = [_LastDataDateKey] ",
              "RETURN ",
              "MAXX(",
              "    FILTER(ALL(Fact_CustomerSnapshot), Fact_CustomerSnapshot[DateKey] < MaxKey), ",
              "    Fact_CustomerSnapshot[DateKey]",
              ")"
            ],
            "isHidden": true
          },
          {
            "name": "Total Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Active Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Churn Flag] = False,",
              "    Fact_CustomerSnapshot[At Risk Flag] = False",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Active Customer Rate",
            "expression": [
              " ",
              "DIVIDE([Active Customers], [Total Customers])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "New Customers This Month",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Trend Category] = \"New\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Customer Growth MoM",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "VAR PrevDate = [_PrevDataDateKey]",
              "VAR ThisMonth =",
              "    CALCULATE(",
              "        DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "        Dim_Date[DateKey] = MaxDate",
              "    )",
              "VAR PrevMonth =",
              "    CALCULATE(",
              "        DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "        Dim_Date[DateKey] = PrevDate",
              "    )",
              "RETURN ",
              "DIVIDE(ThisMonth - PrevMonth, PrevMonth)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Customer Growth QoQ",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevQuarterDate = EOMONTH(MaxDateValue, -3)",
              "",
              "VAR ThisMonthCount = [Total Customers]",
              "VAR PrevQuarterCount = ",
              "    CALCULATE(",
              "        DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevQuarterDate",
              "    )",
              "RETURN ",
              "DIVIDE(ThisMonthCount - PrevQuarterCount, PrevQuarterCount)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Customer Growth YoY",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevYearDate = EOMONTH(MaxDateValue, -12)",
              "",
              "VAR ThisMonthCount = [Total Customers]",
              "VAR PrevYearCount = ",
              "    CALCULATE(",
              "        DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevYearDate",
              "    )",
              "RETURN ",
              "DIVIDE(ThisMonthCount - PrevYearCount, PrevYearCount)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Customer Metrics"
          },
          {
            "name": "Churned Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Churn Flag] = True",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Churn Rate",
            "expression": [
              " ",
              "DIVIDE([Churned Customers], [Total Customers])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Retention Rate",
            "expression": [
              " ",
              "1 - [Churn Rate]"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "At-Risk Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[At Risk Flag] = True",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "At-Risk Rate",
            "expression": [
              " ",
              "DIVIDE([At-Risk Customers], [Total Customers])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Churn Rate MoM Change",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "VAR PrevDate = [_PrevDataDateKey]",
              "VAR ThisChurn =    ",
              "    CALCULATE(        ",
              "        DIVIDE(            ",
              "            CALCULATE(COUNTROWS(Fact_CustomerSnapshot), Fact_CustomerSnapshot[Churn Flag] = True),            ",
              "            COUNTROWS(Fact_CustomerSnapshot)        ",
              "        ),        ",
              "        Dim_Date[DateKey] = MaxDate    ",
              "    )",
              "VAR PrevChurn =    ",
              "    CALCULATE(        ",
              "        DIVIDE(            ",
              "            CALCULATE(COUNTROWS(Fact_CustomerSnapshot), Fact_CustomerSnapshot[Churn Flag] = True),            ",
              "            COUNTROWS(Fact_CustomerSnapshot)        ",
              "        ),        ",
              "        Dim_Date[DateKey] = PrevDate    ",
              "    )",
              "RETURN ThisChurn - PrevChurn"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Churn Rate Trend",
            "expression": [
              " ",
              "DIVIDE(",
              "    CALCULATE(COUNTROWS(Fact_CustomerSnapshot), Fact_CustomerSnapshot[Churn Flag] = True),",
              "    COUNTROWS(Fact_CustomerSnapshot)",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Churn Rate QoQ Change",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevQuarterDate = ",
              "    EOMONTH(MaxDateValue, -3)",
              "VAR ThisChurn = ",
              "    CALCULATE(",
              "        [Churn Rate Trend],",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevQuarterChurn = ",
              "    CALCULATE(",
              "        [Churn Rate Trend],",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevQuarterDate",
              "    )",
              "RETURN ThisChurn - PrevQuarterChurn"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Churn Rate YoY Change",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevYearDate = ",
              "    EOMONTH(MaxDateValue, -12)",
              "VAR ThisChurn = ",
              "    CALCULATE(",
              "        [Churn Rate Trend],",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevYearChurn = ",
              "    CALCULATE(",
              "        [Churn Rate Trend],",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevYearDate",
              "    )",
              "RETURN ThisChurn - PrevYearChurn"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Churn & Retention"
          },
          {
            "name": "Avg Loyalty Score",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    AVERAGE(Fact_CustomerSnapshot[Loyalty Score]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Avg Satisfaction Score",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    AVERAGE(Fact_CustomerSnapshot[Satisfaction Score]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Avg Recency Days",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    AVERAGE(Fact_CustomerSnapshot[Days Since Last Transaction]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Loyalty Score Trend",
            "expression": [
              " ",
              "AVERAGE(Fact_CustomerSnapshot[Loyalty Score])"
            ],
            "formatString": "0.00",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Loyalty MoM Change",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "VAR PrevDate = [_PrevDataDateKey]",
              "VAR ThisMonth = ",
              "    CALCULATE(",
              "        AVERAGE(Fact_CustomerSnapshot[Loyalty Score]), ",
              "        Dim_Date[DateKey] = MaxDate",
              "    )",
              "VAR PrevMonth = ",
              "    CALCULATE(",
              "        AVERAGE(Fact_CustomerSnapshot[Loyalty Score]), ",
              "        Dim_Date[DateKey] = PrevDate",
              "    )",
              "RETURN ThisMonth - PrevMonth"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Loyalty QoQ Change",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevQuarterDate = ",
              "    EOMONTH(MaxDateValue, -3)",
              "VAR ThisLoyalty = ",
              "    CALCULATE(",
              "        [Loyalty Score Trend],",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevQuarterLoyalty = ",
              "    CALCULATE(",
              "        [Loyalty Score Trend],",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevQuarterDate",
              "    )",
              "RETURN ThisLoyalty - PrevQuarterLoyalty"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Loyalty YoY Change",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevYearDate = ",
              "    EOMONTH(MaxDateValue, -12)",
              "VAR ThisLoyalty = ",
              "    CALCULATE(",
              "        [Loyalty Score Trend],",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevYearLoyalty = ",
              "    CALCULATE(",
              "        [Loyalty Score Trend],",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevYearDate",
              "    )",
              "RETURN ThisLoyalty - PrevYearLoyalty"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Loyalty & Satisfaction"
          },
          {
            "name": "Total Transaction Amount",
            "expression": [
              " ",
              "SUM(Fact_CustomerSnapshot[Total Transaction Amt])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Transactions",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Total Transaction Amount (Latest Month)",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    SUM(Fact_CustomerSnapshot[Total Transaction Amt]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Transactions",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Avg Transaction Amount",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    AVERAGE(Fact_CustomerSnapshot[Avg Transaction Amt]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Transactions",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Total Transactions",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    SUM(Fact_CustomerSnapshot[Transaction Count]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Transactions"
          },
          {
            "name": "Avg Transactions Per Customer",
            "expression": [
              " ",
              "DIVIDE([Total Transactions], [Total Customers])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Transactions",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Transaction Volume Trend",
            "expression": [
              " ",
              "SUM(Fact_CustomerSnapshot[Transaction Count])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Transactions",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Customers with Complaints",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Complaint Flag] = TRUE",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Behavior & Growth"
          },
          {
            "name": "Complaint Rate",
            "expression": [
              " ",
              "DIVIDE([Customers with Complaints], [Total Customers])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Behavior & Growth"
          },
          {
            "name": "Avg Growth Rate",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    AVERAGE(Fact_CustomerSnapshot[Growth Rate]),",
              "    Dim_Date[DateKey] = MaxDate",
              ") / 100"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Behavior & Growth"
          },
          {
            "name": "Growing Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    COUNTROWS(Fact_CustomerSnapshot),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[GrowthCategory] = \"Growing\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Behavior & Growth"
          },
          {
            "name": "Declining Customers",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    COUNTROWS(Fact_CustomerSnapshot),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[GrowthCategory] = \"Declining\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Behavior & Growth"
          },
          {
            "name": "Customer Count by Segment",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(Fact_CustomerSnapshot[Customer Key]),",
              "    Dim_Date[DateKey] = MaxDate",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Segment Share",
            "expression": [
              " ",
              "DIVIDE(",
              "    [Customer Count by Segment],",
              "    CALCULATE([Customer Count by Segment], REMOVEFILTERS(Dim_Segment))",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Segments"
          },
          {
            "name": "Champions Count",
            "expression": [
              " ",
              "CALCULATE(",
              "    [Customer Count by Segment],",
              "    Dim_Segment[Segment Code] = \"RF_Champions\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Churned Segment Count",
            "expression": [
              " ",
              "CALCULATE(",
              "    [Customer Count by Segment],",
              "    Dim_Segment[Segment Code] = \"RF_Churned\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Segment Migration (Month)",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "VAR PrevDate = [_PrevDataDateKey]",
              "VAR ThisMonth =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(",
              "            Fact_CustomerSnapshot, ",
              "            \"CK\", Fact_CustomerSnapshot[Customer Key], ",
              "            \"Seg\", Fact_CustomerSnapshot[SegmentKey]",
              "        ),",
              "        Dim_Date[DateKey] = MaxDate",
              "    )",
              "VAR PrevMonth =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(",
              "            Fact_CustomerSnapshot, ",
              "            \"CK\", Fact_CustomerSnapshot[Customer Key], ",
              "            \"Seg\", Fact_CustomerSnapshot[SegmentKey]",
              "        ),",
              "        Dim_Date[DateKey] = PrevDate",
              "    )",
              "RETURN",
              "    COUNTROWS(",
              "        FILTER(",
              "            NATURALINNERJOIN(ThisMonth, SELECTCOLUMNS(PrevMonth, \"CK\", [CK], \"PrevSeg\", [Seg])),",
              "            [Seg] <> [PrevSeg]",
              "        ))"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Segment Migration (Quarter)",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevQuarterDate = ",
              "    EOMONTH(MaxDateValue, -3)",
              "VAR PrevQuarterDateKey =",
              "    CALCULATE(",
              "        MAX(Dim_Date[DateKey]),",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevQuarterDate",
              "    )",
              "VAR ThisMonth =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(Fact_CustomerSnapshot, \"CK\", Fact_CustomerSnapshot[Customer Key], \"Seg\", Fact_CustomerSnapshot[SegmentKey]),",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevQuarter =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(Fact_CustomerSnapshot, \"CK\", Fact_CustomerSnapshot[Customer Key], \"Seg\", Fact_CustomerSnapshot[SegmentKey]),",
              "        Dim_Date[DateKey] = PrevQuarterDateKey",
              "    )",
              "RETURN",
              "    COUNTROWS(",
              "        FILTER(",
              "            NATURALINNERJOIN(ThisMonth, SELECTCOLUMNS(PrevQuarter, \"CK\", [CK], \"PrevSeg\", [Seg])),",
              "            [Seg] <> [PrevSeg]",
              "        )",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Segment Migration (Year)",
            "expression": [
              " ",
              "VAR MaxDateKey = [_LastDataDateKey]",
              "VAR MaxDateValue = ",
              "    CALCULATE(MAX(Dim_Date[Date]), Dim_Date[DateKey] = MaxDateKey)",
              "VAR PrevYearDate = ",
              "    EOMONTH(MaxDateValue, -12)",
              "VAR PrevYearDateKey =",
              "    CALCULATE(",
              "        MAX(Dim_Date[DateKey]),",
              "        REMOVEFILTERS(Dim_Date),",
              "        Dim_Date[Date] = PrevYearDate",
              "    )",
              "VAR ThisMonth =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(Fact_CustomerSnapshot, \"CK\", Fact_CustomerSnapshot[Customer Key], \"Seg\", Fact_CustomerSnapshot[SegmentKey]),",
              "        Dim_Date[DateKey] = MaxDateKey",
              "    )",
              "VAR PrevYear =",
              "    CALCULATETABLE(",
              "        SELECTCOLUMNS(Fact_CustomerSnapshot, \"CK\", Fact_CustomerSnapshot[Customer Key], \"Seg\", Fact_CustomerSnapshot[SegmentKey]),",
              "        Dim_Date[DateKey] = PrevYearDateKey",
              "    )",
              "RETURN",
              "    COUNTROWS(",
              "        FILTER(",
              "            NATURALINNERJOIN(ThisMonth, SELECTCOLUMNS(PrevYear, \"CK\", [CK], \"PrevSeg\", [Seg])),",
              "            [Seg] <> [PrevSeg]",
              "        )",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Segments"
          },
          {
            "name": "Promoters",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    COUNTROWS(Fact_CustomerSnapshot),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Satisfaction Score] >= 4",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "NPS"
          },
          {
            "name": "Detractors",
            "expression": [
              " ",
              "VAR MaxDate = [_LastDataDateKey]",
              "RETURN",
              "CALCULATE(",
              "    COUNTROWS(Fact_CustomerSnapshot),",
              "    Dim_Date[DateKey] = MaxDate,",
              "    Fact_CustomerSnapshot[Satisfaction Score] <= 2",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "NPS"
          },
          {
            "name": "NPS Score",
            "expression": [
              " ",
              "DIVIDE([Promoters] - [Detractors], [Total Customers])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "NPS"
          },
          {
            "name": "NPS Trend",
            "expression": [
              " ",
              "VAR Promo = ",
              "    CALCULATE(",
              "        COUNTROWS(Fact_CustomerSnapshot), ",
              "        Fact_CustomerSnapshot[Satisfaction Score] >= 4",
              "    )",
              "VAR Detract = ",
              "    CALCULATE(",
              "        COUNTROWS(Fact_CustomerSnapshot), ",
              "        Fact_CustomerSnapshot[Satisfaction Score] <= 2",
              "    )",
              "VAR TotalActive = COUNTROWS(Fact_CustomerSnapshot)",
              "RETURN",
              "DIVIDE(Promo - Detract, TotalActive)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "NPS"
          }
        ]
      }
    ],
