          },
          {
            "name": "DateKey",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "DateKey"
          },
          {
            "name": "SegmentKey",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "SegmentKey"
          },
          {
            "name": "Transaction Count",
            "dataType": "int64",
            "sourceColumn": "TransactionCount"
          },
          {
            "name": "Total Transaction Amt",
            "dataType": "double",
            "sourceColumn": "TotalTransactionAmount"
          },
          {
            "name": "Avg Transaction Amt",
            "dataType": "double",
            "sourceColumn": "AvgTransactionAmount"
          },
          {
            "name": "Min Transaction Amt",
            "dataType": "double",
            "sourceColumn": "MinTransactionAmount"
          },
          {
