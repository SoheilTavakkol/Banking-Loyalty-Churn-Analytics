        "fromColumn": "Customer Key",
        "toTable": "Dim_Customer",
        "toColumn": "CustomerKey"
      },
      {
        "name": "0072b5eb-5e35-42ed-8146-6e1514ec1a0f",
        "fromTable": "Dim_Customer",
        "fromColumn": "LocationKey",
        "toTable": "Dim_Location",
        "toColumn": "LocationKey"
      }
