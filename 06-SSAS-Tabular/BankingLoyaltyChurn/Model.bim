            "dataType": "double",
            "sourceColumn": "MaxTransactionAmount"
          },
          {
            "name": "Days Since Last Transaction",
            "dataType": "int64",
            "sourceColumn": "DaysSinceLastTransaction"
          },
          {
            "name": "Recency Score",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "RecencyScore"
          },
          {
            "name": "Frequency Score",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "FrequencyScore"
          },
          {
            "name": "Loyalty Score",
            "dataType": "double",
            "isHidden": true,
            "sourceColumn": "LoyaltyScore"
          },
          {
            "name": "Satisfaction Score",
            "dataType": "double",
            "sourceColumn": "SatisfactionScore"
          },
          {
            "name": "Complaint Flag",
            "dataType": "boolean",
            "sourceColumn": "ComplaintFlag"
          },
          {
            "name": "Churn Flag",
            "dataType": "boolean",
            "sourceColumn": "ChurnFlag"
          },
          {
            "name": "At Risk Flag",
            "dataType": "boolean",
            "sourceColumn": "AtRiskFlag"
          },
          {
            "name": "Trend Category",
            "dataType": "string",
            "sourceColumn": "TrendCategory"
          },
          {
            "name": "Previous Month Transaction Count",
            "dataType": "int64",
            "sourceColumn": "PreviousMonthTransactionCount"
          },
          {
            "name": "Growth Rate",
            "dataType": "double",
            "sourceColumn": "GrowthRate"
          },
          {
            "name": "Final Account Balance",
            "dataType": "double",
            "sourceColumn": "FinalAccountBalance"
          },
          {
            "name": "ETLLoadDate",
            "dataType": "dateTime",
            "isHidden": true,
            "sourceColumn": "ETLLoadDate"
          },
          {
            "name": "ETLBatchID",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "ETLBatchID"
          },
          {
            "type": "calculated",
            "name": "RecencyBucket",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    Fact_CustomerSnapshot[Days Since Last Transaction] <= 30,  \"0-30 days\",",
              "    Fact_CustomerSnapshot[Days Since Last Transaction] <= 60,  \"31-60 days\",",
              "    Fact_CustomerSnapshot[Days Since Last Transaction] <= 90,  \"61-90 days\",",
              "    Fact_CustomerSnapshot[Days Since Last Transaction] <= 180, \"91-180 days\",",
              "    \"180+ days\"",
              ")"
            ]
          },
          {
            "type": "calculated",
            "name": "LoyaltyBand",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    Fact_CustomerSnapshot[Loyalty Score] >= 4.0, \"High (4-5)\",",
              "    Fact_CustomerSnapshot[Loyalty Score] >= 2.5, \"Medium (2.5-4)\",",
              "    \"Low (<2.5)\"",
              ")"
            ]
          },
          {
            "type": "calculated",
            "name": "GrowthCategory",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    Fact_CustomerSnapshot[Churn Flag] = True,   \"Churned\",",
              "    Fact_CustomerSnapshot[Growth Rate] > 20,  \"Growing\",",
              "    Fact_CustomerSnapshot[Growth Rate] < -20, \"Declining\",",
              "    \"Stable\"",
              ")"
            ]
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/ ;BankingDW\",",
                "    DW_Fact_CustomerSnapshot = Source{[Schema=\"DW\",Item=\"Fact_CustomerSnapshot\"]}[Data]",
                "in",
                "    DW_Fact_CustomerSnapshot"
              ]
            }
          }
        ]
      },
